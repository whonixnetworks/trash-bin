# ─── UNINSTALL ────────────────────────────────────────────────────────────────
uninstall_trash_system() {
    check_root

    echo "======================================"
    echo "  Uninstalling Trash System"
    echo "======================================"
    echo ""

    # ── Resolve a safe rm before touching anything ────────────────────────────
    # Prefer the .original backup (pre-wrapper binary) so we never call our
    # own wrapper during cleanup. Fall back to busybox as a last resort.
    REAL_RM=""
    for candidate in /usr/bin/rm.original /bin/rm.original; do
        [[ -f "$candidate" ]] && { REAL_RM="$candidate"; break; }
    done
    if [[ -z "$REAL_RM" ]] && command -v busybox &>/dev/null; then
        REAL_RM="busybox rm"
    fi
    # If neither is available the wrapper is already gone; /usr/bin/rm is real
    if [[ -z "$REAL_RM" ]]; then
        RM_CANDIDATE=$(command -v rm 2>/dev/null || true)
        if [[ -n "$RM_CANDIDATE" ]] && ! grep -qF "safe-rm" "$RM_CANDIDATE" 2>/dev/null; then
            REAL_RM="$RM_CANDIDATE"
        fi
    fi
    [[ -z "$REAL_RM" ]] && die "Cannot locate a real rm — aborting to avoid data loss"

    # ── Restore original rm ───────────────────────────────────────────────────
    RM_RESTORED=false
    for saved in /usr/bin/rm.original /bin/rm.original; do
        if [[ -f "$saved" ]]; then
            target="${saved%.original}"
            log_success "Restoring original rm to $target"
            cp "$saved" "$target"
            $REAL_RM -f "$saved"
            RM_RESTORED=true
            break
        fi
    done
    [[ "$RM_RESTORED" == "false" ]] && \
        log_warning "No rm.original backup found — rm wrapper left in place"

    # ── Remove installed scripts ───────────────────────────────────────────────
    log_success "Removing trash commands"
    for f in \
        "$INSTALL_DIR/safe-rm" \
        "$INSTALL_DIR/bypass-rm" \
        "$INSTALL_DIR/trash-restore" \
        "$INSTALL_DIR/trash-list" \
        "$INSTALL_DIR/trash-empty" \
        "$INSTALL_DIR/trash-info" \
        /etc/cron.daily/trash-cleanup
    do
        [[ -f "$f" ]] && $REAL_RM -f "$f"
    done

    log_warning "Trash directory ($TRASH_BASE) was NOT deleted."
    echo "To remove it manually: sudo $REAL_RM -rf $TRASH_BASE"
    echo ""
    log_success "Uninstall complete!"
}

# ─── HELP / VERSION ───────────────────────────────────────────────────────────
show_help() {
    show_header "Trash System Installer v$VERSION"
    echo -e "${CYAN}Usage:${NC}"
    echo -e "  ${WHITE}sudo $0 COMMAND${NC}"
    echo
    show_section "Commands"
    echo -e "  ${GREEN}✓${NC} ${WHITE}--install${NC}    Install the trash system"
    echo -e "  ${GREEN}✓${NC} ${WHITE}--uninstall${NC}  Remove the trash system"
    echo
    show_section "Flags"
    echo -e "  ${BLUE}ℹ${NC} ${WHITE}-h, --help${NC}     Show this help"
    echo -e "  ${BLUE}ℹ${NC} ${WHITE}-v, --version${NC}  Show version"
    echo
    show_section "Examples"
    echo -e "  ${GRAY}sudo $0 --install${NC}"
    echo -e "  ${GRAY}sudo $0 --uninstall${NC}"
    echo
}

show_version() { echo "Trash System Installer v$VERSION"; }

# ─── MAIN ─────────────────────────────────────────────────────────────────────
main() {
    case "${1:-}" in
        --install)    install_trash_system ;;
        --uninstall)  uninstall_trash_system ;;
        --help|-h)    show_help ;;
        --version|-v) show_version ;;
        *)            show_help; exit 1 ;;
    esac
}

main "$@"
