echo -e "  \${GREEN}● Current Size:\${NC}        \${WHITE}\${TOTAL_SIZE}\${NC}"
echo -e "  \${GREEN}● Total Files:\${NC}         \${WHITE}\${TOTAL_FILES}\${NC}\n"

echo -e "  \${YELLOW}▼ Commands:\${NC}\n"
echo -e "    \${CYAN}├─\${NC} \${MAGENTA}rm <file>\${NC}              \${WHITE}Move file to trash\${NC}"
echo -e "    \${CYAN}├─\${NC} \${MAGENTA}bypass-rm <file>\${NC}       \${WHITE}Permanently delete (caution!)\${NC}"
echo -e "    \${CYAN}├─\${NC} \${MAGENTA}trash-restore <file>\${NC}   \${WHITE}Restore file from trash\${NC}"
echo -e "    \${CYAN}├─\${NC} \${MAGENTA}trash-list\${NC}             \${WHITE}List trashed files\${NC}"
echo -e "    \${CYAN}├─\${NC} \${MAGENTA}sudo trash-empty\${NC}       \${WHITE}Permanently delete all trashed files\${NC}"
echo -e "    \${CYAN}└─\${NC} \${MAGENTA}trash-info\${NC}             \${WHITE}Show this information\${NC}\n"
INFO_EOF
    chmod +x "$INSTALL_DIR/trash-info"

    # ── cron cleanup ──────────────────────────────────────────────────────────
    log_success "Installing automatic cleanup (${MAX_AGE_DAYS}-day retention)"
    # MAX_AGE_DAYS and SAVED_RM expanded from installer config
    cat > /etc/cron.daily/trash-cleanup << CLEANUP_EOF
#!/bin/bash
TRASH_BASE="/trash"
MAX_AGE_DAYS=${MAX_AGE_DAYS}

# Resolve real rm — never call the safe-rm wrapper from cron
if command -v bypass-rm &>/dev/null; then
    RM_CMD="bypass-rm"
