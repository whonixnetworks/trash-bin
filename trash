echo -e "  \${CYAN}\${line} \${RED}\${HEADER_TEXT}\${NC}\${CYAN} \${line}\${NC}\n"

echo -e "  \${GREEN}● Trash Location:\${NC}      \${WHITE}\${TRASH_BASE}\${NC}"
echo -e "  \${GREEN}● Retention Period:\${NC}    \${WHITE}${MAX_AGE_DAYS} days\${NC}"
