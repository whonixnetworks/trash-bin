#!/usr/bin/env bash
# trash — Easy Trash System installer and manager
# author: greedy
# version: 1.3.0
# requires: bash 4.0+, coreutils (find, date, du, mv, cp, stat, awk, sed, wc, grep)

#set -euo pipefail

# ─── CONFIGURATION ────────────────────────────────────────────────────────────
VERSION="1.3.0"
TRASH_BASE="/trash"                    # Base directory for trash storage
INSTALL_DIR="/usr/local/bin"           # Where to install commands
MAX_AGE_DAYS=7                         # Automatic cleanup after N days
SIZE_LIMIT_WARNING="5GB"               # Warning threshold for trash size

# ─── COLOURS ──────────────────────────────────────────────────────────────────
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
MAGENTA='\033[0;35m'
WHITE='\033[1;37m'
GRAY='\033[0;90m'
BOLD="\033[1m"
DIM="\033[2m"
NC='\033[0m'

# ─── HELPERS ──────────────────────────────────────────────────────────────────
log_info()    { echo -e "${BLUE}[INFO]${NC} $1"; }
log_success() { echo -e "${GREEN}[✓]${NC} $1"; }
log_warning() { echo -e "${YELLOW}[WARNING]${NC} $1"; }
log_error()   { echo -e "${RED}[ERROR]${NC} $1"; }

show_header() {
    echo -e "${BLUE}========================================${NC}"
    echo -e "${BLUE}   $1${NC}"
    echo -e "${BLUE}========================================${NC}"
    echo
}

show_section() { echo -e "${MAGENTA}=== $1 ===${NC}"; }

die() { log_error "FATAL: $1"; exit 1; }

check_root() {
    if [[ $EUID -ne 0 ]]; then
        log_error "This installer must be run as root"
        echo "Usage: sudo bash $0 --install"
        exit 1
    fi
}

check_deps() {
    local missing=()
    for cmd in find date du mv cp stat chmod mkdir awk sed wc grep; do
        command -v "$cmd" &>/dev/null || missing+=("$cmd")
    done
    [[ ${#missing[@]} -gt 0 ]] && die "Missing required commands: ${missing[*]}"
}

# ─── INSTALL ──────────────────────────────────────────────────────────────────
install_trash_system() {
    check_root
    check_deps

    echo "======================================"
    echo "  Easy Trash System Installer v${VERSION}"
    echo "======================================"
    echo ""

    # ── Trash directory ───────────────────────────────────────────────────────
    log_success "Creating trash directory at $TRASH_BASE"
    mkdir -p "$TRASH_BASE"
    chmod 1777 "$TRASH_BASE"

    # ── Back up original rm ───────────────────────────────────────────────────
    RM_PATH=$(command -v rm 2>/dev/null || true)
    [[ -z "$RM_PATH" ]] && die "Cannot locate rm binary — is coreutils installed?"

    if [[ ! -f "${RM_PATH}.original" ]]; then
        log_success "Backing up original rm to ${RM_PATH}.original"
        cp "$RM_PATH" "${RM_PATH}.original"
    else
        log_info "Backup already exists at ${RM_PATH}.original — skipping"
    fi
    SAVED_RM="${RM_PATH}.original"

    # ── safe-rm ───────────────────────────────────────────────────────────────
    log_success "Installing safe-rm wrapper"
    cat > "$INSTALL_DIR/safe-rm" << 'SAFE_RM_EOF'
#!/bin/bash
# safe-rm: moves files to /trash instead of deleting them permanently.
TRASH_BASE="/trash"
TRASH_DIR="$TRASH_BASE/$(date +%Y-%m-%d)"

# Ensure today's trash dir exists; if mkdir fails as non-root, try sudo
if [[ ! -d "$TRASH_DIR" ]]; then
    mkdir -p "$TRASH_DIR" 2>/dev/null || {
        if command -v sudo &>/dev/null && [[ $EUID -ne 0 ]]; then
            sudo mkdir -p "$TRASH_DIR" 2>/dev/null
            sudo chmod 1777 "$TRASH_DIR" 2>/dev/null
        fi
    }
fi
chmod 1777 "$TRASH_DIR" 2>/dev/null || true

VERBOSE=false
FILES=()

while [[ $# -gt 0 ]]; do
    case $1 in
        -v|--verbose)                                    VERBOSE=true; shift ;;
        -r|-R|--recursive|-f|--force|-i|--interactive)  shift ;;
        --help)
            echo "safe-rm: files are moved to $TRASH_BASE/<date>/ instead of deleted."
            echo "  bypass-rm <file>    — permanently delete (bypass trash)"
            echo "  trash-restore <f>   — restore a file from trash"
            echo "  trash-list          — list trashed files"
            echo "  trash-info          — show trash system status"
            exit 0
            ;;
        --) shift; FILES+=("$@"); break ;;
        -*) shift ;;
        *)  FILES+=("$1"); shift ;;
    esac
done

if [[ ${#FILES[@]} -eq 0 ]]; then
    echo "Usage: rm [OPTION]... FILE..."
    echo "Files are moved to trash at $TRASH_BASE/<date>/"
    exit 1
fi

rc=0
for file in "${FILES[@]}"; do
    if [[ ! -e "$file" && ! -L "$file" ]]; then
        echo "rm: cannot remove '$file': No such file or directory" >&2
        rc=1
        continue
    fi

    basename_file=$(basename "$file")
    timestamp=$(date +%s)
    # openssl preferred; od fallback for minimal environments
    random_suffix=$(openssl rand -hex 3 2>/dev/null \
        || od -An -N3 -tx1 /dev/urandom 2>/dev/null | tr -d ' \n' \
        || echo "000000")
    unique_name="${timestamp}_${random_suffix}_${basename_file}"
    trash_path="$TRASH_DIR/$unique_name"

    # Try a plain move first; fall back to copy+delete for cross-filesystem moves
    if ! mv -f "$file" "$trash_path" 2>/dev/null; then
        if cp -a "$file" "$trash_path" 2>/dev/null; then
            REAL_RM=""
            for _c in /usr/bin/rm.original /bin/rm.original; do
                [[ -f "$_c" ]] && { REAL_RM="$_c"; break; }
            done
            [[ -z "$REAL_RM" ]] && command -v bypass-rm &>/dev/null && REAL_RM="bypass-rm"
            if [[ -n "$REAL_RM" ]]; then
                $REAL_RM -rf "$file" 2>/dev/null || true
            else
                echo "rm: copied '$file' to trash but could not remove original" >&2
                rc=1
                continue
            fi
        else
            echo "rm: cannot remove '$file': move and copy both failed" >&2
            rc=1
            continue
        fi
    fi

    [[ "$VERBOSE" == "true" ]] && echo "moved '$file' to trash"

    TRASH_INFO="$TRASH_DIR/.trash-info"
    orig_dir=$(cd "$(dirname "$file")" 2>/dev/null && pwd || echo "$PWD")
    {
        printf -- '---\n'
        printf 'trashed_file=%s\n'   "$unique_name"
        printf 'original_path=%s\n' "${orig_dir}/$(basename "$file")"
        printf 'deletion_date=%s\n' "$(date --iso-8601=seconds 2>/dev/null \
                                         || date -u +"%Y-%m-%dT%H:%M:%S+0000")"
        printf 'deleted_by=%s\n'    "${USER:-$(id -un 2>/dev/null || echo unknown)}"
    } >> "$TRASH_INFO" 2>/dev/null || true
done

exit $rc
SAFE_RM_EOF
    chmod +x "$INSTALL_DIR/safe-rm"

    # ── rm wrapper ────────────────────────────────────────────────────────────
    log_success "Installing rm wrapper at ${RM_PATH}"
    cat > "$RM_PATH" << 'RM_WRAPPER_EOF'
#!/bin/bash
exec /usr/local/bin/safe-rm "$@"
RM_WRAPPER_EOF
    chmod +x "$RM_PATH"

    # ── bypass-rm ─────────────────────────────────────────────────────────────
    log_success "Installing bypass-rm"
    # SAVED_RM is expanded by the outer installer shell (no single-quote heredoc)
    cat > "$INSTALL_DIR/bypass-rm" << BYPASS_EOF
#!/bin/bash
# bypass-rm: permanently delete files, bypassing the trash wrapper.
if [[ -f "${SAVED_RM}" ]]; then
    exec "${SAVED_RM}" "\$@"
elif command -v busybox &>/dev/null; then
    exec busybox rm "\$@"
else
    echo "bypass-rm: cannot find original rm binary" >&2
    exit 1
fi
BYPASS_EOF
    chmod +x "$INSTALL_DIR/bypass-rm"

    # ── trash-restore ─────────────────────────────────────────────────────────
    log_success "Installing trash-restore"
    cat > "$INSTALL_DIR/trash-restore" << 'RESTORE_EOF'
#!/bin/bash
TRASH_BASE="/trash"

RED="\033[0;31m";  GREEN="\033[0;32m"; YELLOW="\033[1;33m"
CYAN="\033[0;36m"; MAGENTA="\033[0;35m"; WHITE="\033[1;37m"; NC="\033[0m"

_header() {
    local txt="$1" w=${COLUMNS:-80}
    local pad=$(( (w - ${#txt} - 2) / 2 ))
    local line; line=$(printf "%*s" $pad "" | tr " " "•")
    echo -e "  ${CYAN}${line} ${RED}${txt}${NC}${CYAN} ${line}${NC}\n"
}

if [[ $# -eq 0 ]]; then
    clear
    _header "TRASH RESTORE"
    echo -e "  ${GREEN}● Usage:${NC} trash-restore ${WHITE}<filename>${NC}\n"
    echo -e "  ${YELLOW}▼ Available files in trash:${NC}\n"

    mapfile -t TRASH_FILES < <(
        find "$TRASH_BASE" -type f ! -name ".trash-info" 2>/dev/null \
            | sed 's|.*/||; s/^[0-9]*_[a-f0-9]*_//' \
            | sort \
            | head -20
    )

    if [[ ${#TRASH_FILES[@]} -eq 0 ]]; then
        echo -e "    ${CYAN}└─${NC} ${MAGENTA}No files in trash${NC}\n"
    else
        local_last=$(( ${#TRASH_FILES[@]} - 1 ))
        for i in "${!TRASH_FILES[@]}"; do
            branch="├─"
            [[ $i -eq $local_last ]] && branch="└─"
            echo -e "    ${CYAN}${branch}${NC} ${WHITE}${TRASH_FILES[$i]}${NC}"
        done
        echo
    fi
    exit 0
fi

SEARCH_NAME="$1"

# Escape glob metacharacters so find -name treats the input as a literal string
escaped=$(printf '%s' "$SEARCH_NAME" | sed 's/[*?[]/\\&/g')
FOUND_FILE=$(find "$TRASH_BASE" -type f ! -name ".trash-info" \
    -name "*${escaped}*" 2>/dev/null | head -1)

if [[ -z "$FOUND_FILE" ]]; then
    echo -e "  ${RED}✗ No file matching '${SEARCH_NAME}' found in trash${NC}"
    exit 1
fi

FOUND_BASENAME=$(basename "$FOUND_FILE")
TRASH_DIR=$(dirname "$FOUND_FILE")
INFO_FILE="$TRASH_DIR/.trash-info"

# Show original path — grep -F for literal match; strip key= prefix safely
if [[ -f "$INFO_FILE" ]]; then
    RAW=$(grep -F -A4 "trashed_file=$FOUND_BASENAME" "$INFO_FILE" \
          | grep "^original_path=" | head -1)
    ORIGINAL_PATH="${RAW#original_path=}"
    [[ -n "$ORIGINAL_PATH" ]] && \
        echo -e "  ${CYAN}├─${NC} ${MAGENTA}Original path:${NC} ${WHITE}${ORIGINAL_PATH}${NC}"
fi

BASENAME=$(basename "$FOUND_FILE" | sed 's/^[0-9]*_[a-f0-9]*_//')

# Warn before overwriting an existing file in cwd
if [[ -e "./$BASENAME" ]]; then
    echo -e "  ${YELLOW}⚠ './$BASENAME' already exists in current directory${NC}"
    printf "  Overwrite? (yes/no): "
    read -r OW_REPLY
    if [[ "$OW_REPLY" != "yes" ]]; then
        echo -e "  ${YELLOW}Cancelled${NC}\n"
        exit 1
    fi
fi

mv "$FOUND_FILE" "./$BASENAME"

# Remove the matching block from .trash-info (--- + 4 key=value lines)
if [[ -f "$INFO_FILE" ]]; then
    awk -v target="trashed_file=$FOUND_BASENAME" '
        /^---$/ { buf = $0; next }
        buf != "" {
            if ($0 == target) { buf = ""; skip = 3; next }
            else { print buf; buf = "" }
        }
        skip > 0 { skip--; next }
        { print }
        END { if (buf != "") print buf }
    ' "$INFO_FILE" > "${INFO_FILE}.tmp" \
        && mv "${INFO_FILE}.tmp" "$INFO_FILE" \
        || rm -f "${INFO_FILE}.tmp" 2>/dev/null
fi

echo -e "  ${CYAN}└─${NC} ${GREEN}Restored:${NC} ${WHITE}./$BASENAME${NC}\n"
RESTORE_EOF
    chmod +x "$INSTALL_DIR/trash-restore"

    # ── trash-list ────────────────────────────────────────────────────────────
    log_success "Installing trash-list"
    cat > "$INSTALL_DIR/trash-list" << 'LIST_EOF'
#!/bin/bash
TRASH_BASE="/trash"

RED="\033[0;31m";  GREEN="\033[0;32m"; YELLOW="\033[1;33m"
CYAN="\033[0;36m"; MAGENTA="\033[0;35m"; WHITE="\033[1;37m"; NC="\033[0m"

clear
HEADER_TEXT="TRASH LIST"
w=${COLUMNS:-80}
pad=$(( (w - ${#HEADER_TEXT} - 2) / 2 ))
line=$(printf "%*s" $pad "" | tr " " "•")
echo -e "  ${CYAN}${line} ${RED}${HEADER_TEXT}${NC}${CYAN} ${line}${NC}\n"

TOTAL_SIZE=$(du -sh "$TRASH_BASE" 2>/dev/null | awk '{print $1}')
TOTAL_FILES=$(find "$TRASH_BASE" -type f ! -name ".trash-info" 2>/dev/null | wc -l)
TOTAL_FILES="${TOTAL_FILES// /}"

echo -e "  ${GREEN}● Total Size:${NC}  ${WHITE}${TOTAL_SIZE}${NC}"
echo -e "  ${GREEN}● Total Files:${NC} ${WHITE}${TOTAL_FILES}${NC}\n"

if [[ "$TOTAL_FILES" -eq 0 ]]; then
    echo -e "  ${YELLOW}▼ Trash is empty${NC}\n"
    exit 0
fi

echo -e "  ${YELLOW}▼ Recent files:${NC}\n"
echo -e "    ${MAGENTA}Size${NC}            ${MAGENTA}Date${NC}                 ${MAGENTA}Filename${NC}"
# awk generates the separator — no seq, no brace expansion needed
echo -e "    ${CYAN}$(awk 'BEGIN{for(i=0;i<70;i++)printf "─"; print ""}')${NC}"

# NUL-delimited paths avoid splitting on spaces in filenames
while IFS= read -r -d '' filepath; do
    ts=$(stat -c "%Y" "$filepath" 2>/dev/null \
      || stat -f "%m" "$filepath" 2>/dev/null \
      || echo 0)
    printf '%s\t%s\n' "$ts" "$filepath"
done < <(find "$TRASH_BASE" -type f ! -name ".trash-info" -print0 2>/dev/null) \
    | sort -rn | head -20 \
    | while IFS=$'\t' read -r ts filepath; do
        filename=$(basename "$filepath" | sed 's/^[0-9]*_[a-f0-9]*_//')
        filedate=$(date -d "@$ts" "+%Y-%m-%d %H:%M" 2>/dev/null \
               || date -r  "$ts" "+%Y-%m-%d %H:%M" 2>/dev/null \
               || echo "unknown    ")
        size=$(du -h "$filepath" 2>/dev/null | cut -f1)
        printf "    ${CYAN}├─${NC} ${WHITE}%-10s${NC}  ${WHITE}%-20s${NC} ${WHITE}%s${NC}\n" \
            "$size" "$filedate" "$filename"
    done

echo
LIST_EOF
    chmod +x "$INSTALL_DIR/trash-list"

    # ── trash-empty ───────────────────────────────────────────────────────────
    log_success "Installing trash-empty"
    # SAVED_RM expanded by installer
    cat > "$INSTALL_DIR/trash-empty" << EMPTY_EOF
#!/bin/bash
TRASH_BASE="/trash"

RED="\033[0;31m";  GREEN="\033[0;32m"; YELLOW="\033[1;33m"
CYAN="\033[0;36m"; MAGENTA="\033[0;35m"; WHITE="\033[1;37m"; NC="\033[0m"

if [[ \$EUID -ne 0 ]]; then
    echo -e "  \${RED}✗ This command requires root privileges\${NC}"
    echo -e "  \${YELLOW}▼ Usage:\${NC} \${WHITE}sudo trash-empty\${NC}\n"
    exit 1
fi

TOTAL_FILES=\$(find "\$TRASH_BASE" -type f ! -name ".trash-info" 2>/dev/null | wc -l)
TOTAL_FILES="\${TOTAL_FILES// /}"
TOTAL_SIZE=\$(du -sh "\$TRASH_BASE" 2>/dev/null | awk '{print \$1}')

clear
HEADER_TEXT="EMPTY TRASH"
w=\${COLUMNS:-80}
pad=\$(( (w - \${#HEADER_TEXT} - 2) / 2 ))
line=\$(printf "%*s" \$pad "" | tr " " "•")
echo -e "  \${CYAN}\${line} \${RED}\${HEADER_TEXT}\${NC}\${CYAN} \${line}\${NC}\n"

if [[ "\$TOTAL_FILES" -eq 0 ]]; then
    echo -e "  \${GREEN}● Trash is already empty\${NC}\n"
    exit 0
fi

echo -e "  \${YELLOW}▼ About to permanently delete:\${NC}\n"
echo -e "    \${CYAN}├─\${NC} \${MAGENTA}Files:\${NC} \${WHITE}\${TOTAL_FILES}\${NC}"
echo -e "    \${CYAN}└─\${NC} \${MAGENTA}Size:\${NC}  \${WHITE}\${TOTAL_SIZE}\${NC}\n"

printf "  \${RED}▼ Are you sure? (yes/no):\${NC} "
read -r REPLY
echo

if [[ \$REPLY != "yes" ]]; then
    echo -e "  \${CYAN}└─\${NC} \${YELLOW}Operation cancelled\${NC}\n"
    exit 0
fi

echo -e "  \${CYAN}├─\${NC} \${MAGENTA}Emptying trash...\${NC}"

# Resolve real rm — never call the safe-rm wrapper here
if command -v bypass-rm &>/dev/null; then
    EMPTY_RM="bypass-rm"
elif [[ -f "${SAVED_RM}" ]]; then
    EMPTY_RM="${SAVED_RM}"
elif command -v busybox &>/dev/null; then
    EMPTY_RM="busybox rm"
else
    echo -e "  \${RED}✗ Cannot locate real rm — aborting\${NC}" >&2
    exit 1
fi

# NUL-delimited find avoids glob errors on empty directory
find "\$TRASH_BASE" -mindepth 1 -maxdepth 1 -print0 2>/dev/null \
    | while IFS= read -r -d '' entry; do
        \$EMPTY_RM -rf "\$entry" 2>/dev/null || true
    done

mkdir -p "\$TRASH_BASE"
chmod 1777 "\$TRASH_BASE"

echo -e "  \${CYAN}└─\${NC} \${GREEN}Trash emptied successfully\${NC}\n"
EMPTY_EOF
    chmod +x "$INSTALL_DIR/trash-empty"

    # ── trash-info ────────────────────────────────────────────────────────────
    log_success "Installing trash-info"
    # MAX_AGE_DAYS and SIZE_LIMIT_WARNING expanded from installer config
    cat > "$INSTALL_DIR/trash-info" << INFO_EOF
#!/bin/bash
TRASH_BASE="/trash"

RED="\033[0;31m";  GREEN="\033[0;32m"; YELLOW="\033[1;33m"
